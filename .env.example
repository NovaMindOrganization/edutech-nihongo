# Copy: cp .env.example .env
# Then: docker compose up -d --build

DOMAIN=nihongo.com.vn
# Same-origin via edge nginx: SPA + /api + /ws on this host
CORS_ORIGIN=https://nihongo.com.vn
APP_PUBLIC_URL=https://nihongo.com.vn
# Empty = browser uses relative /api (correct for this compose stack)
VITE_API_BASE_URL=
VITE_APP_TITLE=NihongoCoach

# Only host-facing ports (nginx public, portainer loopback)
HTTP_PORT=80
PORTAINER_PORT=9443

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=app

REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-minio-password

# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-32plus-random-chars-access
JWT_REFRESH_SECRET=replace-with-32plus-random-chars-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

SEPAY_API_KEY=
SEPAY_SECRET=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
SEPAY_BANK_NAME=Vietcombank
SEPAY_BANK_BIN=970436
PAYMENT_CODE_PREFIX=NIHONGO
ORDER_EXPIRY_MINUTES=30

# AI (CPU VPS)
OCR_PP_OCR_MODEL=mobile
OCR_PRELOAD=true
OCR_USE_VISION=true
OCR_REFINE=true
WHISPER_MODEL=base
STT_GEMINI_FALLBACK=true
EDGE_TTS_VOICE=ja-JP-NanamiNeural
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=
PA_ENGINE=azure
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastasia
