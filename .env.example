# Environment variables live next to each service (copy *.env.example -> .env):
#
# client/.env
#   VITE_API_BASE_URL=          # dev: empty (Vite proxy). prod: https://api.your-domain.com
#
# server/app-server/.env
#   JWT_ACCESS_SECRET / JWT_REFRESH_SECRET  # prod: random ≥32 chars (validated on startup)
#   DATABASE_URL, REDIS_URL, CORS_ORIGIN, MINIO_*, APP_PUBLIC_URL
#
# server/ai-server/.env
