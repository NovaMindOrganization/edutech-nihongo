# Generated by bootstrapping-project.sh
NODE_ENV=development
PORT=4000

# CORS — set to your client origin(s)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/app

# Redis
