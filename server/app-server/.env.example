# Generated by bootstrapping-project.sh
NODE_ENV=development
PORT=4000

# CORS — set to your client origin(s)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/app

# Redis
REDIS_URL=redis://localhost:6380

# MinIO/S3 API endpoint used by app-server.
# Dev: localhost:9002 from docker-compose.
# Production can use an internal network endpoint, e.g. http://minio:9000.
# Browser clients upload and view images through app-server, so DB stores object paths, not this URL.
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Production: required, ≥32 chars, not the placeholders below (server exits on weak secrets).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AI service (localhost)
AI_SERVER_URL=http://localhost:8000

# Public API URL for webhook display (production: https://nihongo.com.vn)
APP_PUBLIC_URL=http://localhost:4000

# SePAY fallback (prefer Admin → Cấu hình → SePAY in DB)
SEPAY_API_KEY=
SEPAY_SECRET=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
SEPAY_BANK_NAME=Vietcombank
SEPAY_BANK_BIN=970436
PAYMENT_CODE_PREFIX=NIHONGO
ORDER_EXPIRY_MINUTES=30

# Registration OTP email.
# Resend cooldown is configurable in Admin → Giới hạn & chống spam
# (registration_otp_resend_cooldown_seconds). Env below is fallback when DB key is unset/0.

SMTP_STARTTLS=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=shevchenmex@gmail.com
SMTP_PASS=<APP_PASSWORD_MỚI>
SMTP_FROM="EduTech Nihongo <shevchenmex@gmail.com>"

REGISTRATION_OTP_TTL_SECONDS=600
REGISTRATION_OTP_VERIFY_TOKEN_TTL_SECONDS=900
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=60
REGISTRATION_OTP_MAX_ATTEMPTS=5

# Usage limits (API, AI, auth) are configured in Admin → Cấu hình → Giới hạn & chống spam.
# Requires Redis. Seed creates default keys on first deploy (pnpm db:setup).
