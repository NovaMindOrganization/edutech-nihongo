# Generated by bootstrapping-project.sh — pydantic-settings reads these (see app/core/config.py).
APP_NAME=AI Service
DATABASE_URL=sqlite:///./local.db

# Example PostgreSQL (uncomment to use instead of SQLite)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

REDIS_URL=redis://localhost:6379

# RAG / vector (set as needed)
VECTOR_DB_TYPE=pgvector
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Japanese OCR (PP-OCRv5 / PaddleOCR 3.x GPU) ---
# Run: ../../scripts/setup-ocr-gpu.sh
OCR_ENGINE=paddleocr
OCR_USE_GPU=true
OCR_MIN_CONFIDENCE=0.5
# server (accuracy) | mobile (faster, less VRAM)
OCR_PP_OCR_MODEL=server
# Load PP-OCRv5 at server start (avoids "Creating model" on first /ocr request)
OCR_PRELOAD=true
# Notebook photo preprocess (grid removal, upscale, crop)
OCR_PREPROCESS=true
OCR_PREPROCESS_MIN_WIDTH=2000
OCR_PREPROCESS_WARP=true
# Pipeline: Paddle + vision LLM (admin provider) → LLM refine (layout/order)
OCR_USE_VISION=true
OCR_REFINE=true
# Legacy: auto | paddle (no vision) | gemini (vision-only, no Paddle/refine)
OCR_HANDWRITING_ENGINE=auto
# Vision model for Agent Router OCR (must support images: claude-opus-4-6, gpt-4o, …)
# OCR vision (admin keys ocr_* override these when llm_config is sent from app-server)
# OCR_AGENTROUTER_VISION_MODEL=claude-opus-4-6
# OCR_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# Skip HF connectivity check on PP-OCRv5 cold start
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
# Optional cloud fallback (not required if Paddle is installed)
# GOOGLE_VISION_API_KEY=

# --- Gemini (required for AI speaking / OCR explanation) ---
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=

# STT — see app/prompts/*.md for Gemini system prompts per feature
# GPU: bash ../../scripts/setup-ai-gpu.sh then:
# WHISPER_MODEL=base
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# OCR_USE_GPU=true
# STT_DEFAULT_LANGUAGE=ja
# STT_GEMINI_FALLBACK=true
# STT_VAD_FILTER=true
# STT_BEAM_SIZE=5
# STT_SAMPLE_RATE=16000
# STT_MIN_AUDIO_BYTES=500
# STT_MAX_DURATION_SEC=120
# EDGE_TTS_VOICE=ja-JP-NanamiNeural

# Pronunciation assessment (Azure Speech + ffmpeg)
# PA_ENGINE=azure
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
# MAX_AUDIO_BASE64_BYTES=2097152
# MIN_AUDIO_SECONDS=1
# MAX_AUDIO_SECONDS=10
# SILENCE_RMS_THRESHOLD=80
# FFMPEG_TIMEOUT_SECONDS=20
