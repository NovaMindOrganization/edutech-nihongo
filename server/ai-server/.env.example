# Generated by bootstrapping-project.sh — pydantic-settings reads these (see app/core/config.py).
APP_NAME=AI Service
DATABASE_URL=sqlite:///./local.db

# Example PostgreSQL (uncomment to use instead of SQLite)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

REDIS_URL=redis://localhost:6379

# RAG / vector (set as needed)
VECTOR_DB_TYPE=pgvector
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Japanese OCR (PaddleOCR GPU) ---
# Run: ../../scripts/setup-ocr-gpu.sh
OCR_ENGINE=paddleocr
OCR_USE_GPU=true
OCR_MIN_CONFIDENCE=0.5
# Optional cloud fallback (not required if Paddle is installed)
# GOOGLE_VISION_API_KEY=

# --- Gemini (required for AI speaking / OCR explanation) ---
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=

# STT — see app/prompts/*.md for Gemini system prompts per feature
# GPU: bash ../../scripts/setup-ai-gpu.sh then:
# WHISPER_MODEL=base
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# OCR_USE_GPU=true
# STT_DEFAULT_LANGUAGE=ja
# STT_GEMINI_FALLBACK=true
# STT_VAD_FILTER=true
# STT_BEAM_SIZE=5
# STT_SAMPLE_RATE=16000
# STT_MIN_AUDIO_BYTES=500
# STT_MAX_DURATION_SEC=120
# EDGE_TTS_VOICE=ja-JP-NanamiNeural

