{
  "name": "edutech-nihongo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:client": "pnpm --dir client dev",
    "build:client": "pnpm --dir client build",
    "db:setup": "pnpm --dir server/app-server db:setup",
    "dev:app-server": "pnpm --dir server/app-server dev",
    "build:app-server": "pnpm --dir server/app-server build",
    "dev:ai-server": "cd server/ai-server && conda run --no-capture-output -n edutech-nihongo python -m uvicorn app.main:app --reload --port 8000"
  },
  "dependencies": {
    "multer": "^2.1.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0"
  }
}
